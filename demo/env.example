# AgentLink demo — environment variables
#
# Copy to .env and fill in. The demo scripts read from process.env.

# Starknet Sepolia RPC endpoint (public or Alchemy / Infura / Voyager)
STARKNET_RPC_URL=https://starknet-sepolia.public.blastapi.io/rpc/v0_7

# Sender wallet (Braavos on Sepolia). Address + privkey (dev only — do NOT commit).
SENDER_ADDRESS=0x0
SENDER_PRIVKEY=0x0

# Deployed contracts
AGENTLINK_ESCROW_ADDRESS=0x0
FUNDING_TOKEN_ADDRESS=0x04718f5a0fc34cc1af16a1cdee98ffb20c31f5cd61d6ab07201858f4287c938d
# ^ STRK on Starknet Sepolia. Verify before use.

# Agent target (where the agent is authorized to send funds)
AGENT_RECIPIENT_ADDRESS=0x0

# AVNU paymaster (optional — if unset, sponsored mode is skipped)
AVNU_PAYMASTER_API_KEY=
